{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash",
            "timeout": 30,
            "args": [
              "${CLAUDE_PLUGIN_ROOT}/hooks/setup.sh"
            ]
          },
          {
            "type": "command",
            "command": "bash",
            "timeout": 5,
            "args": [
              "${CLAUDE_PLUGIN_ROOT}/hooks/session-status.sh"
            ]
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash",
            "timeout": 5,
            "args": [
              "${CLAUDE_PLUGIN_ROOT}/hooks/session-end-warn.sh"
            ]
          }
        ]
      }
    ]
  }
}
